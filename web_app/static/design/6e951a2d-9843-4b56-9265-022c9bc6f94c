function loadLedgerBoot(){
  const xhr = new XMLHttpRequest();
  xhr.open("GET", "/api/design-data", false);
  xhr.send(null);
  if(xhr.status < 200 || xhr.status >= 300){
    throw new Error("无法读取本地账本数据：" + xhr.status);
  }
  return JSON.parse(xhr.responseText);
}

