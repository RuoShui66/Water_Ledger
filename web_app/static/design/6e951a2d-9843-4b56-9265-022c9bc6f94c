// 支出分类聚合（用于报告/总览）
function isCountable(t){ return t.countable !== false; }
function cashflowTxns(txns){ return txns.filter(isCountable); }
function expenseByCat(txns){
  const m = {};
  cashflowTxns(txns).filter(t=>t.amount<0).forEach(t=>{ m[t.cat]=(m[t.cat]||0)+(-t.amount); });
  return Object.entries(m).map(([cat,v])=>({cat,v})).sort((a,b)=>b.v-a.v);
}

// ============ 跨期流水（用于统计页的 年/全部 视图）============
const TODAY = LEDGER_BOOT.today;
function zhDate(value){
  if(!value) return "";
  const [y,m,d] = value.slice(0,10).split("-");
  return `${y} 年 ${Number(m)} 月 ${Number(d)} 日`;
}
const ALL_TXNS = LEDGER_BOOT.allTxns.sort((a,b)=> a.date<b.date?1:-1);
const EARLIEST = ALL_TXNS[ALL_TXNS.length-1]?.day || TODAY;

function daysBetween(a,b){ return Math.round((new Date(b)-new Date(a))/86400000); }
function pad2(n){ return String(n).padStart(2,"0"); }
function ymd(d){ return `${d.getFullYear()}-${pad2(d.getMonth()+1)}-${pad2(d.getDate())}`; }

function filterPeriod(txns, period, offset=0){
  const today = new Date(TODAY);
  let startStr, endStr, label, days;

  if(period==="all"){
    return { rows:txns, days: daysBetween(EARLIEST, TODAY)+1, label:"全部", canPrev:false, canNext:false };
  }

  if(period==="week"){
    const end = new Date(today); end.setDate(today.getDate() - 7*offset);
    const start = new Date(end); start.setDate(end.getDate() - 6);
    startStr = ymd(start); endStr = ymd(end);
    days = 7;
    label = `${startStr.slice(5)} ~ ${endStr.slice(5)}`;
  } else if(period==="month"){
    const d = new Date(today.getFullYear(), today.getMonth()-offset, 1);
    const mEnd = new Date(d.getFullYear(), d.getMonth()+1, 0);
    const periodEnd = mEnd < today ? mEnd : today;
    startStr = ymd(d); endStr = ymd(periodEnd);
    days = daysBetween(startStr, endStr)+1;
    label = `${d.getFullYear()} 年 ${d.getMonth()+1} 月`;
  } else if(period==="year"){
    const y = today.getFullYear()-offset;
    const start = new Date(y,0,1);
    const end = y===today.getFullYear()? today : new Date(y,11,31);
    startStr = ymd(start); endStr = ymd(end);
    days = daysBetween(startStr, endStr)+1;
    label = `${y} 年`;
  }

  const rows = txns.filter(t=>(t.day || t.date.slice(0,10))>=startStr && (t.day || t.date.slice(0,10))<=endStr);
  const canPrev = startStr > EARLIEST;
  const canNext = offset > 0;
  return { rows, days, label, start:startStr, end:endStr, canPrev, canNext };
}

function summarize(txns){
  const countable = cashflowTxns(txns);
  const income = countable.filter(t=>t.amount>0).reduce((s,t)=>s+t.amount,0);
  const expense = -countable.filter(t=>t.amount<0).reduce((s,t)=>s+t.amount,0);
  const net = income-expense;
  const byCat = expenseByCat(countable);
  return { income, expense, net, byCat };
}

function monthKey(date){ return date.slice(0,7); }
function monthLabel(key){ return `${key.slice(2,4)}/${key.slice(5)}`; }
function monthlySeries(txns){
  const m = {};
  cashflowTxns(txns).forEach(t=>{
    const k = monthKey(t.day || t.date);
    if(!m[k]) m[k] = { m:monthLabel(k), income:0, expense:0, net:0 };
    if(t.amount>0) m[k].income += t.amount;
    if(t.amount<0) m[k].expense += -t.amount;
    m[k].net += t.amount;
  });
  return Object.entries(m).sort(([a],[b])=>a.localeCompare(b)).map(([,v])=>v);
}
